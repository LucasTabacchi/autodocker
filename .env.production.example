DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_USE_SQLITE=false
DJANGO_ALLOWED_HOSTS=your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false
POSTGRES_DB=autodocker
POSTGRES_USER=autodocker
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
AUTODOCKER_ASYNC_MODE=celery
AUTODOCKER_ENABLE_RUNTIME_JOBS=false
AUTODOCKER_TOKEN_ENCRYPTION_KEY=replace-with-a-separate-token-encryption-key
SUPABASE_STORAGE_BUCKET=autodocker-media
SUPABASE_STORAGE_S3_ENDPOINT_URL=https://project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_S3_REGION=us-east-1
SUPABASE_STORAGE_ACCESS_KEY_ID=replace-with-s3-access-key-id
SUPABASE_STORAGE_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key
SUPABASE_STORAGE_MEDIA_PATH_PREFIX=
