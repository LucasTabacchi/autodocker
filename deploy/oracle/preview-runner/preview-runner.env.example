DJANGO_SECRET_KEY=replace-with-runner-secret
DJANGO_DEBUG=false
AUTODOCKER_DEPLOYMENT_ROLE=preview_runner
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SESSION_COOKIE_SECURE=false

DATABASE_URL=postgresql://postgres:replace-me@db.internal:5432/autodocker?sslmode=require
CELERY_BROKER_URL=redis://default:replace-me@redis.internal:6379/0
CELERY_RESULT_BACKEND=redis://default:replace-me@redis.internal:6379/0

AUTODOCKER_ASYNC_MODE=inline
AUTODOCKER_ENABLE_RUNTIME_JOBS=true
AUTODOCKER_PREVIEW_BACKEND=local
AUTODOCKER_PREVIEW_KEEP_WORKSPACES=false
AUTODOCKER_PREVIEW_TTL_SECONDS=1800
AUTODOCKER_PREVIEW_MAX_TTL_SECONDS=2700
AUTODOCKER_PREVIEW_MAX_BUNDLE_MB=100
AUTODOCKER_PREVIEW_URL_STRATEGY=runner_managed
AUTODOCKER_PREVIEW_PUBLIC_BASE_DOMAIN=previews.example.com
AUTODOCKER_PREVIEW_RUNNER_TOKEN=replace-with-long-rotated-token
AUTODOCKER_PREVIEW_RUNNER_REQUEST_TIMEOUT=60
AUTODOCKER_PREVIEW_RUNNER_MAX_ACTIVE_SESSIONS=2
AUTODOCKER_PREVIEW_PER_SESSION_CPU=0.75
AUTODOCKER_PREVIEW_PER_SESSION_MEMORY_MB=2560
AUTODOCKER_PREVIEW_HTTP_READY_TIMEOUT_SECONDS=75
AUTODOCKER_PREVIEW_CADDY_ENABLED=true
AUTODOCKER_PREVIEW_CADDY_CONFIG_PATH=/etc/caddy/Caddyfile
AUTODOCKER_PREVIEW_CADDY_ROUTES_DIR=/etc/caddy/routes
AUTODOCKER_PREVIEW_CADDY_RELOAD_COMMAND=caddy reload --config /etc/caddy/Caddyfile

AUTODOCKER_TOKEN_ENCRYPTION_KEY=replace-with-separate-token-key

SUPABASE_STORAGE_BUCKET=autodocker-media
SUPABASE_STORAGE_S3_ENDPOINT_URL=https://project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_S3_REGION=us-east-1
SUPABASE_STORAGE_ACCESS_KEY_ID=replace-with-s3-access-key-id
SUPABASE_STORAGE_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key
SUPABASE_STORAGE_MEDIA_PATH_PREFIX=
