DJANGO_SECRET_KEY=replace-with-a-real-secret-key
DJANGO_DEBUG=false
DJANGO_USE_SQLITE=false
DJANGO_ALLOWED_HOSTS=autodocker.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://autodocker.example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false

AUTODOCKER_APP_BASE_URL=https://autodocker.example.com
AUTODOCKER_ASYNC_MODE=celery

# Supabase Postgres URL. Keep sslmode=require in the query string.
DATABASE_URL=postgresql://postgres:replace-me@db.example.supabase.co:5432/postgres?sslmode=require

# External Redis for Celery broker/results.
CELERY_BROKER_URL=redis://default:replace-me@redis.example.com:6379/0
CELERY_RESULT_BACKEND=redis://default:replace-me@redis.example.com:6379/0

# Configure a real SMTP backend if you want email delivery in production.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=autodocker@example.com
