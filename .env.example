# Base local para desarrollo simple con `manage.py`.
# Django carga automáticamente este archivo al iniciar la app.

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
AUTODOCKER_DEPLOYMENT_ROLE=app
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SESSION_COOKIE_SECURE=false
POSTGRES_DB=autodocker
POSTGRES_USER=autodocker
POSTGRES_PASSWORD=autodocker
POSTGRES_HOST=db
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
AUTODOCKER_ASYNC_MODE=celery
AUTODOCKER_ENABLE_RUNTIME_JOBS=true
AUTODOCKER_VALIDATION_BACKEND=local
AUTODOCKER_PREVIEW_BACKEND=local
AUTODOCKER_PREVIEW_RUNNER_BASE_URL=
AUTODOCKER_PREVIEW_RUNNER_TOKEN=
AUTODOCKER_PREVIEW_TTL_SECONDS=1800
AUTODOCKER_PREVIEW_MAX_BUNDLE_MB=100
AUTODOCKER_PREVIEW_PUBLIC_BASE_DOMAIN=
AUTODOCKER_PREVIEW_URL_STRATEGY=runner_managed
AUTODOCKER_PREVIEW_RUNNER_REQUEST_TIMEOUT=60
AUTODOCKER_VALIDATION_EXECUTOR_REPO=owner/autodocker-validator
AUTODOCKER_VALIDATION_EXECUTOR_WORKFLOW=validate.yml
AUTODOCKER_VALIDATION_EXECUTOR_TOKEN=github-token-with-executor-workflow-access
AUTODOCKER_VALIDATION_BUNDLE_TTL_SECONDS=86400
AUTODOCKER_VALIDATION_MAX_BUNDLE_MB=100
AUTODOCKER_TOKEN_ENCRYPTION_KEY=change-me-too

# Optional: private Supabase Storage bucket for uploaded ZIPs.
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_S3_ENDPOINT_URL=
SUPABASE_STORAGE_S3_REGION=
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_MEDIA_PATH_PREFIX=
