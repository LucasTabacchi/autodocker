DJANGO_SECRET_KEY=autodocker-docker-dev-secret-key-change-me
DJANGO_DEBUG=true
DJANGO_USE_SQLITE=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SESSION_COOKIE_SECURE=false
POSTGRES_DB=autodocker
POSTGRES_USER=autodocker
POSTGRES_PASSWORD=autodocker
POSTGRES_HOST=db
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
AUTODOCKER_ASYNC_MODE=celery
AUTODOCKER_ENABLE_RUNTIME_JOBS=true
AUTODOCKER_TOKEN_ENCRYPTION_KEY=autodocker-docker-token-key-change-me
