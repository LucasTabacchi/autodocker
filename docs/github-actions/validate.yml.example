name: AutoDocker validation executor

run-name: Validate ${{ inputs.job_id }}

on:
  workflow_dispatch:
    inputs:
      job_id:
        required: true
        type: string
      analysis_id:
        required: true
        type: string
      bundle_url:
        required: true
        type: string
      bundle_sha256:
        required: true
        type: string

jobs:
  validate:
    runs-on: ubuntu-latest
    permissions:
      contents: read
    steps:
      - name: Download bundle
        run: |
          curl -fsSL "${{ inputs.bundle_url }}" -o bundle.zip

      - name: Verify checksum
        run: |
          echo "${{ inputs.bundle_sha256 }}  bundle.zip" | sha256sum -c -

      - name: Extract bundle
        run: |
          unzip -q bundle.zip -d bundle

      - name: Run validation
        working-directory: bundle
        run: |
          set -uo pipefail
          start_ts=$(date +%s)
          : > validation.log

          run_and_capture() {
            local label="$1"
            shift
            {
              printf '==> %s\n' "$label"
            } >> validation.log
            "$@" 2>&1 | tee -a validation.log
            return ${PIPESTATUS[0]}
          }

          success=true
          summary=""
          command_display=""
          command_json="[]"
          exit_code=0

          if [ -f docker-compose.yml ]; then
            command_display="docker compose -f docker-compose.yml build"
            command_json='["docker","compose","-f","docker-compose.yml","build"]'

            if ! run_and_capture "docker compose -f docker-compose.yml config" docker compose -f docker-compose.yml config; then
              success=false
              summary="docker compose config failed"
              exit_code=1
            elif ! run_and_capture "$command_display" docker compose -f docker-compose.yml build; then
              success=false
              summary="docker compose build failed"
              exit_code=1
            else
              summary="docker compose build completed successfully"
            fi
          else
            command_display="docker build -t autodocker-validate ."
            command_json='["docker","build","-t","autodocker-validate","."]'

            if ! run_and_capture "$command_display" docker build -t autodocker-validate .; then
              success=false
              summary="docker build failed"
              exit_code=1
            else
              summary="docker build completed successfully"
            fi
          fi

          duration=$(( $(date +%s) - start_ts ))
          {
            printf '\n==> Result\n'
            printf 'Summary: %s\n' "$summary"
            printf 'Command: %s\n' "$command_display"
            printf 'Duration: %ss\n' "$duration"
            printf 'Success: %s\n' "$success"
          } >> validation.log

          VALIDATION_SUCCESS="$success" \
          VALIDATION_SUMMARY="$summary" \
          VALIDATION_COMMAND_JSON="$command_json" \
          VALIDATION_DURATION="$duration" \
          python - <<'PY'
          import json
          import os
          from pathlib import Path

          Path("result.json").write_text(
              json.dumps(
                  {
                      "success": os.environ["VALIDATION_SUCCESS"] == "true",
                      "summary": os.environ["VALIDATION_SUMMARY"],
                      "command": json.loads(os.environ["VALIDATION_COMMAND_JSON"]),
                      "duration_seconds": int(os.environ["VALIDATION_DURATION"]),
                  }
              ),
              encoding="utf-8",
          )
          PY

          exit "$exit_code"

      - name: Upload artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: validation-results
          path: |
            bundle/result.json
            bundle/validation.log
